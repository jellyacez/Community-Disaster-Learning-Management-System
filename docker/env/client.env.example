# ─────────────────────────────────────────────────────────────────────────────
# Client Environment Variables (Vite)
# Copy this file to client/.env and fill in the values before running the app.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Base URL of the backend server (used for auth redirects, etc.)
VITE_BASE_URL=http://localhost:5000

# URL of this frontend app (used for OAuth callbacks, CORS, etc.)
VITE_FRONTEND_URL=http://localhost:5173

# Feature Flags
VITE_DISABLE_MFA=true

# Vite internal flag — keep as true in development
DEV=true
