# ─────────────────────────────────────────────────────────────────────────────
# Server Environment Variables
# Copy this file to server/.env and fill in the values before running the app.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server port
PORT=5000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# When using Docker Compose, DB_HOST must be "db" (the service name), not localhost.
DB_HOST=db
DB_PORT=5432
DB_DATABASE=LMS_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ── Auth & JWT ────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

BETTER_AUTH_URL=http://localhost:5000

# Generate secrets using the rotate-better-auth.js script:  npm run rotate-better-auth
BETTER_AUTH_SECRETS="2:YOUR_SECRET_1, 1:YOUR_SECRET_2"

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Feature Flags ─────────────────────────────────────────────────────────────
DISABLE_MFA=true

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
# In dev this points to the Vite dev server.
# In Docker Compose it points to the nginx container on port 80.
FRONTEND_URL=http://localhost:5173

# ── AWS S3 (optional — only needed if media uploads are enabled) ──────────────
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=ap-southeast-1
# S3_BUCKET_NAME=your_bucket_name
